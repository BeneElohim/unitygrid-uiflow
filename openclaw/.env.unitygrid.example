# UnityGrid + OpenClaw Gateway — Environment Template
# ──────────────────────────────────────────────────────
# Copy this file to .env.unitygrid and fill in real values.
# NEVER commit .env.unitygrid to git.
#
# Usage:
#   source .env.unitygrid
#   openclaw gateway --config configs/unitygrid.gateway.json5

# ── Gateway auth token (generate with: openssl rand -hex 32) ──────────────────
export UG_GATEWAY_TOKEN="paste-long-random-hex-here"

# ── NVIDIA NIM (sovereign default LLM) ───────────────────────────────────────
export NEMO_API_BASE="https://integrate.api.nvidia.com/v1"
export NEMO_API_KEY="nvapi-your-key-here"
export NEMO_MODEL="nvidia/nemotron-70b-instruct"

# ── Optional: OpenRouter BYO route (disabled by default) ─────────────────────
# Uncomment and set to enable the openrouter failover route.
# export OPENROUTER_API_KEY="sk-or-your-key-here"
# export OPENROUTER_MODEL="meta-llama/llama-3.1-405b-instruct"

# ── UnityGrid UI port (for CORS allowedOrigins in gateway config) ─────────────
export UG_UI_PORT="8502"
export UG_GATEWAY_PORT="8765"
